# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your-super-secret-key-change-this
PORT=5000

# FTP Server Configuration (YOUR ACTUAL FTP SERVER)
FTP_HOST=your-ftp-server.com  # Replace with your FTP server IP or domain
FTP_PORT=21
FTP_USER=anonymous  # Or your FTP username
FTP_PASS=  # Or your FTP password

# Note: Your FTP server should have this folder structure:
# /movies/action/
# /movies/comedy/
# /movies/drama/
# etc.
